.ai-customer-container {
  position: fixed;
  right: 24rpx;
  bottom: 200rpx;
  z-index: 9999;
}

.ai-btn-float {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.5);
  animation: pulse 2s infinite;
}

.ai-btn-float.hidden {
  display: none;
}

.ai-btn-icon {
  width: 48rpx;
  height: 48rpx;
}

.ai-btn-text {
  font-size: 20rpx;
  color: #fff;
  margin-top: 4rpx;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

.chat-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: #f5f5f5;
  z-index: 10000;
  display: flex;
  flex-direction: column;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.close-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
  border-radius: 50%;
}

.close-icon {
  width: 48rpx;
  height: 48rpx;
  filter: brightness(0) invert(1);
}

.ai-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
}

.header-title {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: center;
  margin: 0 16rpx;
}

.header-placeholder {
  width: 80rpx;
}

.chat-messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.welcome-msg,
.user-msg {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.user-msg {
  flex-direction: row-reverse;
}

.msg-avatar {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-avatar {
  background: #e8e8e8;
}

.msg-bubble {
  max-width: 480rpx;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  margin: 0 16rpx;
  position: relative;
}

.bot-bubble {
  background: #fff;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.msg-text {
  font-size: 28rpx;
  line-height: 44rpx;
  word-break: break-all;
  white-space: pre-wrap;
}

.loading-bubble {
  opacity: 0.7;
}

.seize-seat {
  height: 20rpx;
}

.quick-questions {
  padding: 0 20rpx 20rpx;
}

.quick-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #667eea;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.chat-input-area {
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 0 8rpx;
}

.chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: transparent;
}

.send-btn {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  background: #ddd;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
